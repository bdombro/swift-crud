PORT=8222
DB_PATH=db.sqlite
# DB_DEBUG=true

# Auth — uncomment to sign cookies with HMAC
AUTH_SECRET=zbtRUF0HIsCxq0GHvZ3ZMv3qXingTNTFwkb2Jf63FKA=

# Session cookie — production cross-subdomain (api + app on same parent domain)
# COOKIE_DOMAIN=foo.com
# COOKIE_SECURE=false   # local HTTP only; omit Secure on session cookies

# CORS — comma-separated frontend origins (required for browser credentialed requests)
# CORS_ALLOWED_ORIGINS=https://foo.com

# SMTP — uncomment to send real emails instead of printing to stdout
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=user@example.com
# SMTP_PASSWORD=secret
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=My App
# SMTP_TLS_MODE=starttls   # starttls (default), tls (implicit on 465), or none (plaintext, dev only)
# SMTP_TLS_INSECURE=false  # true to skip certificate validation (dev only)
# SMTP_TIMEOUT_SECONDS=30
# SMTP_TLS_SERVERNAME=mail.example.com  # when SMTP_HOST is an MX hostname (_dc-mx.*) or differs from the TLS cert

# OpenObserve — direct log ingestion (use loopback http://127.0.0.1:5080/ on contabo production server)
# OPENOBSERVE_URL=http://127.0.0.1:5080/api/default/fooapp/_json
# OPENOBSERVE_USER=logger@gmail.com
# OPENOBSERVE_PASS=...

# CONSOLE_LOGS_ENABLED=true  # Set to false in production to disable writing duplicate logs locally to stdout/stderr
